{{define "query.tmpl"}}<!DOCTYPE html>
<html lang="en">
<head>
<meta http-equiv="Content-Type" content="text/html; charset=UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Query - GWS Database</title>
<link rel="stylesheet" href="/static/gwsdb.css">
</head>
<body bgcolor="#FFFFFF" text="#000000" link="#0000EE" vlink="#551A8B">
<center>
<table border="0" cellpadding="4" cellspacing="0" class="gwsdb-wrap">
<tr bgcolor="#000080">
<td><font color="#FFFFFF" face="Arial,Helvetica,sans-serif" size="+1"><b>GWS Database</b></font></td>
</tr>
<tr bgcolor="#DDDDDD">
<td>
<font face="Arial,Helvetica,sans-serif" size="-1">
<a href="/">Home</a> |
<a href="/query">Query IP</a> |
<a href="/scans">Scans</a>
</font>
</td>
</tr>
<tr>
<td>
<font face="Arial,Helvetica,sans-serif" size="-1">

<p>Enter an IP address within a Google ASN to look up its PTR record, or a 1e100.net hostname to look up its A/AAAA records, and estimate its geographic location.</p>

<form method="GET" action="/query">
<table border="0" cellpadding="4" cellspacing="0">
<tr>
<td>IP or 1e100.net Hostname</td>
<td><input type="text" name="ip" size="28" value="{{.Query}}"></td>
<td><input type="submit" value="Query"></td>
</tr>
</table>
</form>

{{if .Submitted}}
<hr>
{{if .Error}}
<p><font color="#CC0000">{{.Error}}</font></p>
{{else if .QueryIsHostname}}
<div class="gwsdb-scroll">
<table border="1" cellpadding="6" cellspacing="0" width="100%">
<tr bgcolor="#EEEEEE"><td colspan="3"><b>Query Result: {{.Query}}</b></td></tr>
<tr bgcolor="#EEEEEE"><td><b>Hostname</b></td><td><b>A (IPv4)</b></td><td><b>AAAA (IPv6)</b></td></tr>
{{range .HostnameForms}}
<tr>
<td><tt><a href="/query?ip={{.Hostname}}">{{.Hostname}}</a></tt></td>
<td>{{if .IPv4}}{{range .IPv4}}<tt><a href="/query?ip={{.Addr}}">{{.Addr}}</a></tt> {{if eq .Status "Reachable"}}<font color="#008000">✓</font>{{else if eq .Status "Unreachable"}}<font color="#CC0000">✗</font>{{else}}-{{end}}<br>{{end}}{{else}}<i>none</i>{{end}}</td>
<td>{{if .IPv6}}{{range .IPv6}}<tt><a href="/query?ip={{.Addr}}">{{.Addr}}</a></tt> {{if eq .Status "Reachable"}}<font color="#008000">✓</font>{{else if eq .Status "Unreachable"}}<font color="#CC0000">✗</font>{{else}}-{{end}}<br>{{end}}{{else}}<i>none</i>{{end}}</td>
</tr>
{{end}}
{{if .Matched}}
<tr>
<td>Airport Code</td>
<td colspan="2"><tt>{{.AirportCode}}</tt></td>
</tr>
<tr>
<td>Estimated Location</td>
<td colspan="2">{{if .City}}{{.City}}, {{.Country}}{{else}}<i>Airport code not in database, cannot estimate</i>{{end}}</td>
</tr>
{{else}}
<tr>
<td colspan="3"><i>This does not match the known 1e100.net naming convention, cannot estimate a location</i></td>
</tr>
{{end}}
</table>
</div>
{{else}}
<div class="gwsdb-scroll">
<table border="1" cellpadding="6" cellspacing="0" width="100%">
<tr bgcolor="#EEEEEE"><td colspan="2"><b>Query Result: {{.Query}}</b></td></tr>
<tr>
<td width="30%">PTR Record</td>
<td><tt>{{if .PTRHostnames}}{{range $i, $h := .PTRHostnames}}{{if $i}}<br>{{end}}<a href="/query?ip={{$h}}">{{$h}}</a>{{end}}{{else}}<i>(no PTR record)</i>{{end}}</tt></td>
</tr>
{{if .Matched}}
<tr>
<td>Airport Code</td>
<td><tt>{{.AirportCode}}</tt></td>
</tr>
<tr>
<td>Estimated Location</td>
<td>{{if .City}}{{.City}}, {{.Country}}{{else}}<i>Airport code not in database, cannot estimate</i>{{end}}</td>
</tr>
{{else if .PTRHostnames}}
<tr>
<td>Estimated Location</td>
<td><i>This PTR does not match the known 1e100.net naming convention, cannot parse</i></td>
</tr>
{{end}}
{{if .HasHistory}}
<tr bgcolor="#EEEEEE"><td colspan="2"><b>Reachability Overview</b></td></tr>
<tr><td>Current Status</td><td>{{if eq .Status "Reachable"}}<font color="#008000">✓ Reachable</font>{{else if eq .Status "Unreachable"}}<font color="#CC0000">✗ Unreachable</font>{{else}}-{{end}}</td></tr>
<tr><td>First Seen</td><td>{{.FirstSeen}}</td></tr>
<tr><td>Last Reachable</td><td>{{.LastSeen}}</td></tr>
<tr><td>Total Times Seen</td><td>{{.TimesSeen}}</td></tr>
<tr><td>Last RTT</td><td>{{if .LastRTTMs}}{{.LastRTTMs}} ms{{else}}-{{end}}</td></tr>
{{else}}
<tr><td colspan="2"><i>This IP is not in the known scan results (it may not have been scanned, or was never found reachable)</i></td></tr>
{{end}}
</table>
</div>

{{if .Checks}}
<p></p>
<div class="gwsdb-scroll">
<table border="1" cellpadding="4" cellspacing="0" width="100%">
<tr bgcolor="#EEEEEE"><td colspan="5"><b>Check History</b> (last {{len .Checks}} checks, including the probe request sent at the time)</td></tr>
<tr bgcolor="#EEEEEE"><td><b>Time</b></td><td><b>Result</b></td><td><b>Reason</b></td><td><b>Probe Request</b></td><td><b>RTT</b></td></tr>
{{range .Checks}}
<tr>
<td>{{.Time}}</td>
<td>{{if .OK}}<font color="#008000">✓ Reachable</font>{{else}}<font color="#CC0000">✗ Unreachable</font>{{end}}</td>
<td>{{if .ReasonLabel}}{{.ReasonLabel}}{{else}}-{{end}}</td>
<td><font size="-1">{{if .Probe}}{{.Probe}}<br>{{end}}{{if .Detail}}<tt>{{.Detail}}</tt>{{end}}</font></td>
<td>{{if .RTT}}{{.RTT}} ms{{else}}-{{end}}</td>
</tr>
{{end}}
</table>
</div>
{{end}}

<p></p>
<div class="gwsdb-scroll">
<table border="1" cellpadding="6" cellspacing="0" width="100%">
<tr bgcolor="#EEEEEE"><td colspan="2"><b>报告IP</b></td></tr>
<tr>
<td colspan="2">
<form method="POST" action="/report">
<input type="hidden" name="ip" value="{{.Query}}">
备注（可选）：<input type="text" name="comment" size="40" maxlength="500">
<button type="submit" name="verdict" value="usable">可用</button>
<button type="submit" name="verdict" value="unusable">不可用</button>
</form>
</td>
</tr>
</table>
</div>

{{if .Reports}}
<p></p>
<div class="gwsdb-scroll">
<table border="1" cellpadding="4" cellspacing="0" width="100%">
<tr bgcolor="#EEEEEE"><td colspan="5"><b>社区报告</b>（{{.UsableCount}} 可用 / {{.UnusableCount}} 不可用）</td></tr>
<tr bgcolor="#EEEEEE"><td><b>时间</b></td><td><b>结论</b></td><td><b>前缀</b></td><td><b>AS</b></td><td><b>备注</b></td></tr>
{{range .Reports}}
<tr>
<td>{{.Time}}</td>
<td>{{if .Verdict}}<font color="#008000">✓ 可用</font>{{else}}<font color="#CC0000">✗ 不可用</font>{{end}}</td>
<td><tt>{{if .ReporterPrefix}}{{.ReporterPrefix}}{{else}}-{{end}}</tt></td>
<td>{{if .ReporterASN}}AS{{.ReporterASN}}{{if .ReporterASName}} {{.ReporterASName}}{{end}}{{else}}-{{end}}</td>
<td>{{if .Comment}}{{.Comment}}{{else}}-{{end}}</td>
</tr>
{{end}}
</table>
</div>
{{end}}
{{end}}
{{end}}

<hr>
<p><font size="-2" color="#666666">
Location estimates are based on the <a href="https://github.com/lennylxx/ipv6-hosts/wiki/1e100.net">1e100.net PTR naming convention</a> (a community-maintained, unofficial document, for reference only).
</font></p>

</font>
</td>
</tr>
<tr bgcolor="#DDDDDD">
<td align="center">
<font face="Arial,Helvetica,sans-serif" size="-2" color="#666666">
{{if buildRevision}}commit <a href="{{buildCommitURL}}">{{buildRevision}}</a> &middot; {{buildDate}}{{else}}<a href="{{repoURL}}">gwsdb</a>{{end}}
</font>
</td>
</tr>
</table>
</center>
</body>
</html>
{{end}}

{{define "report_confirm.tmpl"}}<!DOCTYPE html>
<html lang="zh">
<head>
<meta http-equiv="Content-Type" content="text/html; charset=UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>确认 - GWS Database</title>
<link rel="stylesheet" href="/static/gwsdb.css">
</head>
<body bgcolor="#FFFFFF" text="#000000" link="#0000EE" vlink="#551A8B">
<center>
<table border="0" cellpadding="4" cellspacing="0" class="gwsdb-wrap">
<tr bgcolor="#000080">
<td><font color="#FFFFFF" face="Arial,Helvetica,sans-serif" size="+1"><b>GWS Database</b></font></td>
</tr>
<tr bgcolor="#DDDDDD">
<td>
<font face="Arial,Helvetica,sans-serif" size="-1">
<a href="/">首页</a> |
<a href="/query">查询 IP</a> |
<a href="/scans">扫描记录</a>
</font>
</td>
</tr>
<tr>
<td>
<font face="Arial,Helvetica,sans-serif" size="-1">

<p><b>确认提交报告</b></p>

<div class="gwsdb-scroll">
<table border="1" cellpadding="6" cellspacing="0" width="100%">
<tr bgcolor="#EEEEEE"><td colspan="2"><b>以下内容将被存储并公开显示</b></td></tr>
<tr><td width="30%">目标IP</td><td><tt>{{.IP}}</tt></td></tr>
<tr><td>结论</td><td>{{if .Verdict}}<font color="#008000">✓ 可用</font>{{else}}<font color="#CC0000">✗ 不可用</font>{{end}}</td></tr>
{{if .Comment}}<tr><td>备注</td><td>{{.Comment}}</td></tr>{{end}}
<tr><td>你的前缀</td><td><tt>{{if .ReporterPrefix}}{{.ReporterPrefix}}{{else}}(未知){{end}}</tt></td></tr>
<tr><td>你的AS</td><td>{{if .ReporterASN}}AS{{.ReporterASN}}{{if .ReporterASName}} {{.ReporterASName}}{{end}}{{else}}(未知){{end}}</td></tr>
</table>
</div>

<p><font color="#CC0000">你的IP地址路由公告前缀与AS号码将对查看此IP报告历史的任何人可见。</font></p>

<form method="POST" action="/report">
<input type="hidden" name="ip" value="{{.IP}}">
<input type="hidden" name="comment" value="{{.Comment}}">
<input type="hidden" name="confirm" value="1">
<button type="submit" name="verdict" value="{{if .Verdict}}usable{{else}}unusable{{end}}">{{if .Verdict}}确认提交为可用{{else}}确认提交为不可用{{end}}</button>
</form>
<p><a href="/query?ip={{.IP}}">取消</a></p>

</font>
</td>
</tr>
<tr bgcolor="#DDDDDD">
<td align="center">
<font face="Arial,Helvetica,sans-serif" size="-2" color="#666666">
{{if buildRevision}}commit <a href="{{buildCommitURL}}">{{buildRevision}}</a> &middot; {{buildDate}}{{else}}<a href="{{repoURL}}">gwsdb</a>{{end}}
</font>
</td>
</tr>
</table>
</center>
</body>
</html>
{{end}}

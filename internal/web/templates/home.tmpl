{{define "home.tmpl"}}<!DOCTYPE html>
<html lang="en">
<head>
<meta http-equiv="Content-Type" content="text/html; charset=UTF-8">
<title>Home - GWS Database</title>
</head>
<body bgcolor="#FFFFFF" text="#000000" link="#0000EE" vlink="#551A8B">
<center>
<table border="0" cellpadding="4" cellspacing="0" width="760">
<tr bgcolor="#000080">
<td><font color="#FFFFFF" face="Arial,Helvetica,sans-serif" size="+1"><b>GWS Database</b></font></td>
</tr>
<tr bgcolor="#DDDDDD">
<td>
<font face="Arial,Helvetica,sans-serif" size="-1">
<a href="/">Home</a> |
<a href="/query">Query IP</a> |
<a href="/scans">Scans</a>
</font>
</td>
</tr>
<tr>
<td>
<font face="Arial,Helvetica,sans-serif" size="-1">

<p>The table below lists tracked Google Web Server (GWS) IP addresses and their reachability status.</p>

<p>
{{if .FilterUp}}<b>Reachable only</b>{{else}}<a href="/?status=up">Reachable only</a>{{end}}
&nbsp;|&nbsp;
{{if .FilterUp}}<a href="/?status=all">All (including history)</a>{{else}}<b>All (including history)</b>{{end}}
&nbsp;&nbsp;{{.Count}} total{{if .Truncated}} (showing only the most recent {{.Count}}){{end}}
</p>

<form method="get" action="/">
{{if not .FilterUp}}<input type="hidden" name="status" value="all">{{end}}
<input type="text" name="q" value="{{.Search}}" placeholder="Search IP or PTR" size="30">
<input type="submit" value="Search">
{{if .Search}}&nbsp;<a href="/?{{if not .FilterUp}}status=all{{end}}">Clear</a>{{end}}
</form>

{{if .IPs}}
<table border="1" cellpadding="4" cellspacing="0" width="100%">
<tr bgcolor="#EEEEEE">
<td><b><a href="{{(index .Sort "ip").URL}}">IP Address</a> {{(index .Sort "ip").Arrow}}</b></td>
<td><b><a href="{{(index .Sort "ptr").URL}}">PTR</a> {{(index .Sort "ptr").Arrow}}</b></td>
<td><b>Country</b></td>
<td><b><a href="{{(index .Sort "status").URL}}">Status</a> {{(index .Sort "status").Arrow}}</b></td>
<td><b><a href="{{(index .Sort "first_seen").URL}}">First Seen</a> {{(index .Sort "first_seen").Arrow}}</b></td>
<td><b><a href="{{(index .Sort "last_seen").URL}}">Last Reachable</a> {{(index .Sort "last_seen").Arrow}}</b></td>
<td><b><a href="{{(index .Sort "rtt").URL}}">Last RTT</a> {{(index .Sort "rtt").Arrow}}</b></td>
</tr>
{{range .IPs}}
<tr>
<td><tt><a href="/query?ip={{.IP}}">{{.IP}}</a></tt></td>
<td>{{if .PTR}}<tt>{{.PTR}}</tt>{{else}}-{{end}}</td>
<td>{{if .CountryCode}}<img src="https://bgp.he.net/images/flags/{{.CountryCode}}.gif" alt="{{.CountryCode}}" title="{{.Country}}" width="16" height="11">{{end}} {{if .Country}}{{.Country}}{{else}}-{{end}}</td>
<td>{{if eq .Status "Reachable"}}<font color="#008000">✓ Reachable</font>{{else if eq .Status "Unreachable"}}<font color="#CC0000">✗ Unreachable</font>{{else}}-{{end}}</td>
<td>{{.FirstSeen}}</td>
<td>{{.LastSeen}}</td>
<td>{{if .LastRTTMs}}{{.LastRTTMs}} ms{{else}}-{{end}}</td>
</tr>
{{end}}
</table>
{{else}}
<p><i>No data yet. Please run a scan and import the results first.</i></p>
{{end}}

<hr>
<table border="0" cellpadding="2" cellspacing="0">
<tr><td colspan="2"><b>Statistics</b></td></tr>
<tr><td>Total Known IPs</td><td>{{.Stats.TotalKnownIPs}}</td></tr>
<tr><td>Total Scans</td><td>{{.Stats.TotalScans}}</td></tr>
<tr><td>Last Scan</td><td>{{.LastScanAt}}{{if .ScanMode}} ({{.ScanMode}}){{end}}</td></tr>
</table>

</font>
</td>
</tr>
<tr bgcolor="#DDDDDD">
<td align="center">
<font face="Arial,Helvetica,sans-serif" size="-2" color="#666666">
GWS Database &mdash; Tracking Google Web Server IP reachability in China
</font>
</td>
</tr>
</table>
</center>
</body>
</html>
{{end}}
